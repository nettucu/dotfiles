$ErrorActionPreference = 'Stop'

if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
  Write-Host 'winget is not available; skipping Windows package bootstrap.'
  exit 0
}

$packages = @(
{{- range .windows.packages }}
  '{{ . }}'
{{- end }}
)

foreach ($packageId in $packages) {
  $listed = winget list --exact --id $packageId --accept-source-agreements --disable-interactivity 2>$null | Out-String
  if ($listed -match 'No installed package found') {
    Write-Host "Installing $packageId"
    winget install --exact --id $packageId --accept-package-agreements --accept-source-agreements --disable-interactivity
  } else {
    Write-Host "$packageId already installed"
  }
}
