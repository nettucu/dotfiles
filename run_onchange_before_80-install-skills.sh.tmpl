#!/usr/bin/env bash
# Installs global skills whenever chezmoidata.yaml changes.
# hash: {{ include (joinPath .chezmoi.sourceDir ".chezmoidata.yaml") | sha256sum }}

set -euo pipefail

export PATH="${HOME}/.local/bin:${PATH}"
eval "$(fnm env --shell bash 2>/dev/null)" || true

if ! command -v npx >/dev/null 2>&1; then
  echo "npx not found; skipping skills install." >&2
  exit 0
fi

echo "Installing global skills..."
{{ range $source, $skills := .skills -}}
echo "  {{ $source }}: {{ join "," $skills }}"
npx skills add -g {{ $source }} --skill {{ join " " $skills }} -a claude-code -a codex -a gemini-cli -a antigravity -y
{{ end -}}
