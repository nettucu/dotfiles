# vim: ft=sshconfig
# ~/.ssh/config - managed by chezmoi
# Source: ~/.dotfiles/private_dot_ssh/private_config.tmpl

{{ if eq .chezmoi.os "darwin" -}}
# Work (macOS only)
Include ~/.ssh/config_work
{{- end }}

# Global defaults
Host *
    HashKnownHosts no
    ForwardAgent no
    ForwardX11 no
    AddressFamily any
    CheckHostIP no
    ServerAliveInterval 60
    ServerAliveCountMax 120
    Compression yes # disable per host
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%C
    ControlPersist 10m

# Personal hosts
Host octoprint.local
    HostName octoprint.local
    Compression no
    User pi

Host zeppelin
    Compression no
    User catalin
    ForwardAgent yes

# Home router - needs legacy algorithms
Host 192.168.1.1
    Compression no
    KexAlgorithms +diffie-hellman-group1-sha1
    Ciphers +3des-cbc

# Local/lab networks - relaxed host checking, legacy algorithm support
Host 192.168.1.* 192.168.56.* 192.168.57.* *.local
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    CheckHostIP no
    Compression no
    PubkeyAcceptedAlgorithms +ssh-rsa
    HostkeyAlgorithms +ssh-rsa

# GitHub
Host github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github_ctrifu
    IdentitiesOnly yes
