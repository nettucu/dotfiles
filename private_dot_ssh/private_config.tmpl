# vim: ft=sshconfig
# ~/.ssh/config — managed by chezmoi
# Source: ~/.dotfiles/private_dot_ssh/private_config.tmpl

# ─── Global defaults ──────────────────────────────────────────────────────────
Host *
    HashKnownHosts no
    ForwardAgent no
    ForwardX11 no
    AddressFamily any
    CheckHostIP no
    ServerAliveInterval 60
    ServerAliveCountMax 120
    Compression yes # disable per host
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h:%p
    ControlPersist 10m

# ─── Personal hosts ───────────────────────────────────────────────────────────
Host octoprint.local
    HostName octoprint.local
    Compression no
    User pi

Host zeppelin
    Compression no
    User catalin
    ForwardAgent yes

# Home router — needs legacy algorithms
Host 192.168.1.1
    Compression no
    KexAlgorithms +diffie-hellman-group1-sha1
    Ciphers +3des-cbc

# Local/lab networks — relaxed host checking, legacy algorithm support
Host 192.168.1.* 192.168.56.* 192.168.57.* *.local
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    CheckHostIP no
    Compression no
    PubkeyAcceptedAlgorithms +ssh-rsa
    HostkeyAlgorithms +ssh-rsa

# ─── GitHub ───────────────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
# On Oracle VPN the corporate proxy is reachable — use it; otherwise connect directly
Match host github.com exec "nc -z -w 1 www-proxy-wdc.oracle.com 80 2>/dev/null"
    ProxyCommand connect-proxy -H www-proxy-wdc.oracle.com:80 %h %p

{{ end -}}
Host github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github_ctrifu
    IdentitiesOnly yes

{{ if eq .chezmoi.os "darwin" -}}
# ─── Work — Oracle (macOS only) ───────────────────────────────────────────────
Host orahub.oci.oraclecorp.com
    User git
    IdentityFile ~/.ssh/id_ed25519_orahub
    IdentitiesOnly yes

# Lab/test hosts — legacy algorithm support
Host template* sol* linux* upgr* ol6* ol7* ol8* ol9*
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    CheckHostIP no
    PubkeyAcceptedAlgorithms +ssh-rsa
    HostkeyAlgorithms +ssh-rsa

    
