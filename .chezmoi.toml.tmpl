# Repository-provided chezmoi defaults.
# Keep machine-specific overrides in ~/.config/chezmoi/chezmoi.toml.
{{- $role := promptStringOnce . "role" "Machine role [workstation/server]" -}}


### Set encryption to age and hope the file doesn't get screwed
encryption = "age"

[chezmoi]
  sourceDir = {{ .chezmoi.sourceDir | quote }}

[data]
  role = {{ $role | quote }}

[age]
  identity = "~/.config/age/key.txt"
